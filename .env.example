# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_TASK_QUEUE=task_queue
RABBITMQ_DLQ=task_queue.dlq
RABBITMQ_EXCHANGE=task_exchange
RABBITMQ_PREFETCH=2

# Worker
WORKER_MAX_RETRIES=3
WORKER_RETRY_DELAY_MS=1000

# SSRF protection — comma-separated hostnames allowed in goto actions
# Leave unset to use the default (example.com only)
# Set to empty string "" to disable the check (dev only)
ALLOWED_DOMAINS=example.com

# API (Phase 4)
API_PORT=3000
